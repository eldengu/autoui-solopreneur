{
  "CashPanel": {
    "root": "card",
    "elements": {
      "card": {
        "type": "Card",
        "props": {
          "title": "Cash Position",
          "subtitle": "All accounts"
        },
        "children": [
          "stack"
        ]
      },
      "stack": {
        "type": "Stack",
        "props": {
          "direction": "col",
          "gap": "md"
        },
        "children": [
          "total",
          "grid",
          "trend",
          "badge"
        ]
      },
      "total": {
        "type": "Metric",
        "props": {
          "label": "Total cash",
          "value": "$48,250",
          "delta": "+$3,200 this month",
          "trend": "up"
        }
      },
      "grid": {
        "type": "Grid",
        "props": {
          "columns": 2,
          "gap": "sm"
        },
        "children": [
          "checking",
          "savings"
        ]
      },
      "checking": {
        "type": "Metric",
        "props": {
          "label": "Checking",
          "value": "$32,100"
        }
      },
      "savings": {
        "type": "Metric",
        "props": {
          "label": "Savings",
          "value": "$16,150"
        }
      },
      "trend": {
        "type": "LineGraph",
        "props": {
          "points": [
            38000,
            41200,
            39800,
            43500,
            45050,
            48250
          ],
          "labels": [
            "Jan",
            "Feb",
            "Mar",
            "Apr",
            "May",
            "Jun"
          ]
        }
      },
      "badge": {
        "type": "Badge",
        "props": {
          "label": "Healthy",
          "tone": "positive"
        }
      }
    }
  },
